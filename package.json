    "ember-cli-deploy-gzip": "^3.0.0",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-cli-fastboot": "^4.1.5",
    "ember-cli-head": "^2.0.0",
    "ember-cli-htmlbars": "^6.3.0",
