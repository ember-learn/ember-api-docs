    "@ember/string": "^3.1.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/compat": "^3.9.3",
    "@embroider/core": "^3.5.9",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.1",
    "@embroider/webpack": "^3.2.1",
    "@eslint/js": "^9.35.0",
