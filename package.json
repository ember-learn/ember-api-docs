    "qunit": "^2.24.1",
    "qunit-dom": "^3.5.0",
    "sanitize-html": "^2.3.2",
    "semver": "^7.5.4",
    "semver-compare": "^1.0.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^36.0.1",
    "testem": "^3.10.0",
    "tracked-built-ins": "^4.1.0",
    "webpack": "^5.101.3"
  },
  "engines": {
    "node": ">= 20.11",
    "pnpm": "10"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "ember-data>ember-inflector": "^6.0.0"
    }
  },
  "cacheDirectories": [
    "node_modules"
  ],
  "ember": {
    "edition": "octane"
  },
  "fastbootDependencies": [
    "crypto",
    "algoliasearch",
    "node-fetch",
    "abortcontroller-polyfill",
    "abortcontroller-polyfill/dist/cjs-ponyfill"
  ],
  "ember-addon": {
    "paths": [
      "lib/api-docs-data"
    ]
  }
